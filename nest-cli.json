{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": false,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      { "include": "stat-arb/demo/public/**/*", "outDir": "dist" },
      { "include": "ui/public/**/*", "outDir": "dist" }
    ]
  }
}
