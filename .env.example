# App
NODE_ENV=development
PORT=3100

# Database — Postgres on port 5433 (Lira-Bridge owns 5432).
# Two roles exist:
#   meridian_markets — superuser-ish account used by migrations.
#   meridian_markets_app — runtime app role; SELECT,INSERT only on treasury_movements.
# DATABASE_URL_APP is used by the running NestJS service; DATABASE_URL by the
# migration CLI. Keeping them split is what makes the append-only privilege
# guarantee real — the running app cannot UPDATE/DELETE movement rows even if
# a bug or attacker tries.
DATABASE_URL=postgresql://meridian_markets:meridian_markets@localhost:5433/meridian_markets
DATABASE_URL_APP=postgresql://meridian_markets_app:meridian_markets_app@localhost:5433/meridian_markets

# Cross-service auth — Lira-Bridge sends this in `x-meridian-client-key`.
# Single shared-secret header is the v1 contract; later swap for mTLS or
# signed JWT. Treat as a real secret.
MERIDIAN_CLIENT_KEY=dev-meridian-client-key-change-me

# ── Yield provider (Phase 0) ────────────────────────────────────────────────
# Default mock; flip to false ONLY after KYB completes with the chosen issuer.
# When true the MockYieldProvider simulates principal/yield with deterministic
# math (no external calls).
MOCK_YIELD_ENABLED=true

# Mock-specific knobs.
# MOCK_YIELD_APR: annualised yield, decimal (0.05 = 5 %).
# MOCK_YIELD_SETTLE_MS: simulated provider latency on deposit/withdraw.
MOCK_YIELD_APR=0.05
MOCK_YIELD_SETTLE_MS=250

# ── Ondo USDY (Phase 0 real provider — KYB-gated) ──────────────────────────
# Dormant until MOCK_YIELD_ENABLED=false. Populate only post-KYB.
# Reads go through ISecretProvider — do not import process.env from yield code.
ONDO_API_BASE_URL=https://api.ondo.finance
ONDO_API_KEY=
ONDO_INSTITUTION_ID=

# ── Yield-sync cron ─────────────────────────────────────────────────────────
# How often to call IYieldProvider.fetchYieldEarned() and write a
# YIELD_ACCRUAL movement if the position has appreciated. 5 min default.
YIELD_SYNC_INTERVAL_MS=300000

# ── Hedge venue (Phase 1 — FX hedge scaffold) ──────────────────────────────
# Default mock; flip to false ONLY after venue KYB completes with Hyperliquid
# (or chosen alt). MockHedgeVenue simulates a short-ILS perp position with
# deterministic FX drift and a constant 10bps/day funding placeholder.
# First-party only — never customer-facing.
MOCK_HEDGE_ENABLED=true

# Mock-specific knobs.
# MOCK_HEDGE_FX_DRIFT_BPS_PER_DAY: linear ILS drift in bps/day; positive = ILS
#   weakens vs USD (short profits). 2 bps/day ≈ realistic baseline drift.
# MOCK_HEDGE_SETTLE_MS: simulated venue latency on open/close.
MOCK_HEDGE_FX_DRIFT_BPS_PER_DAY=2
MOCK_HEDGE_SETTLE_MS=0

# ── Hedge orchestrator (Phase 1 — circuit breakers + monitor) ───────────────
# HEDGE_MAX_FUNDING_BPS: kill switch — pause hedging if venue funding rate
#   exceeds this threshold (basis points). 100 bps = 1%.
# HEDGE_MAX_FEED_STALENESS_MS: kill switch — pause if Lira-Bridge exposure
#   feed is older than this (ms). 300000 = 5 minutes.
# HEDGE_RATIO_PCT: fraction of outstanding USDC exposure to hedge. 100 = 100%.
# HEDGE_REBALANCE_THRESHOLD_PCT: don't rebalance unless the imbalance exceeds
#   this percentage of the target notional. 5 = 5%.
# HEDGE_MONITOR_INTERVAL_MS: how often the monitor cron polls. 60000 = 1 min.
# HEDGE_ILS_SIGMA_BPS: 1σ ILS/USD daily vol in bps for liquidation buffer math.
#   94 ≈ 0.94% daily 3σ move, consistent with ~5% annualised ILS vol.
# HEDGE_POSITION_STALENESS_MS: how old a cached position can be before we
#   re-fetch from the venue. 30000 = 30s.
HEDGE_MAX_FUNDING_BPS=100
HEDGE_MAX_FEED_STALENESS_MS=300000
HEDGE_RATIO_PCT=100
HEDGE_REBALANCE_THRESHOLD_PCT=5
HEDGE_MONITOR_INTERVAL_MS=60000
HEDGE_ILS_SIGMA_BPS=94
HEDGE_POSITION_STALENESS_MS=30000

# ── Stat-arb engine (pairs trading) ────────────────────────────────────────
# MOCK_TRADING_ENABLED: default true = synthetic MockTradingVenue for the
#   offline demo. The real execution path is selected by EXECUTION_MODE below.
# DEMO_BAR_COUNT / DEMO_PAIR_A / DEMO_PAIR_B: synthetic-demo knobs.
MOCK_TRADING_ENABLED=true
DEMO_BAR_COUNT=90
DEMO_PAIR_A=BTC
DEMO_PAIR_B=ETH

# ── Market-data feed ────────────────────────────────────────────────────────
# FEED_SOURCE: mock | binance.
#   mock    — synthetic generator (offline dev, deterministic).
#   binance — REAL Binance public market data. No API key, no account, no KYB:
#             these REST endpoints are public. This is the live data spine.
# FEED_QUOTE: quote asset the engine trades against (BTC -> BTCUSDT).
# FEED_INTERVAL: kline interval for the live feed.
# BINANCE_PUBLIC_BASE_URL: override for a regional mirror.
FEED_SOURCE=mock
FEED_QUOTE=USDT
FEED_INTERVAL=1m
BINANCE_PUBLIC_BASE_URL=https://api.binance.com

# Reference data sources (TESSERA) — the opportunity scanner + reference read
# endpoint sweep these alongside Binance. All PUBLIC, no key. Override only for
# a mirror/proxy. Pyth gives true FX OHLC (scannable); DefiLlama/Bit2C are spot
# reference levels surfaced in the UI "data sources" readout.
PYTH_BENCHMARKS_BASE_URL=https://benchmarks.pyth.network
DEFILLAMA_STABLECOINS_BASE_URL=https://stablecoins.llama.fi
BIT2C_BASE_URL=https://bit2c.co.il
# GeckoTerminal — free, no-key DEX OHLCV across 100+ chains (the market-discovery
# frontier; scannable via the dex-eth-bluechip preset).
GECKOTERMINAL_BASE_URL=https://api.geckoterminal.com/api/v2
# Hyperliquid — free, no-key perp-CLOB market data (OHLCV/L2/funding). The
# maker-rebate order-book venue the MM book needs; hl-perps preset.
HYPERLIQUID_BASE_URL=https://api.hyperliquid.xyz

# ── Live paper-trading loop ─────────────────────────────────────────────────
# To paper-trade for real against live data, set:
#   FEED_SOURCE=binance  EXECUTION_MODE=paper  LIVE_AUTOSTART=true
# The loop pulls real bars, runs the pairs strategy, and routes orders to the
# PaperVenue (real prices, simulated fills). No real money, no account.
LIVE_AUTOSTART=false
LIVE_PAIR_A=BTC
LIVE_PAIR_B=ETH
LIVE_BETA=1
LIVE_Z_LOOKBACK=20
LIVE_ENTRY_Z=2
LIVE_EXIT_Z=0.5
LIVE_NOTIONAL_UNITS=1000000000
LIVE_POLL_INTERVAL_MS=15000

# ── Automated market-making books (run alongside the stat-arb portfolio) ─────
# Quoter catalogue (mmStrategyRegistry): mm-symmetric | mm-avellaneda-stoikov |
# mm-glft. Each MM book quotes ONE instrument and earns the spread; control plane
# at /api/market-making. MM_SOURCE is the DEFAULT MM VENUE for a bare launch:
# 'hyperliquid' = the maker-rebate perp CLOB (the desk's primary MM venue); the live
# book is priced at that venue's REAL maker fee (venue-fees.ts), not MM_MAKER_FEE_BPS.
# (The global FEED_SOURCE stays Binance — HL is perps-only, a per-book source.)
# MM_GAMMA / MM_KAPPA: Avellaneda-Stoikov risk aversion + order-arrival decay.
# MM_MIN/MAX_HALF_SPREAD_BPS: quote half-spread rails (bps of mid).
# MM_MAKER_FEE_BPS: screener heuristic only now (live fee = per-venue); − = rebate.
MM_STRATEGY_ID=mm-glft
MM_SYMBOL=BTC
MM_SOURCE=hyperliquid
MM_QUOTE_SIZE_UNITS=1000000000
MM_CAPITAL_UNITS=100000000000
MM_POLL_INTERVAL_MS=15000
MM_VOL_WINDOW_BARS=30
MM_GAMMA=0.0025
MM_KAPPA=2
MM_MIN_HALF_SPREAD_BPS=1
MM_MAX_HALF_SPREAD_BPS=200
MM_MAX_INVENTORY_LOTS=8
MM_MAKER_FEE_BPS=-0.2
MM_MAX_DRAWDOWN_PCT=10
# Restart-safe books: MM_PERSIST=true checkpoints each MM book to Postgres
# (mm_book_state) every tick + rehydrates OPEN books on boot (P&L/positions survive
# restart). Needs Postgres + `npm run migration:run`. MM_FLATTEN_ON_SHUTDOWN=true
# closes all MM inventory before the final checkpoint on SIGINT/SIGTERM.
MM_PERSIST=false
MM_FLATTEN_ON_SHUTDOWN=false

# ── Execution mode ──────────────────────────────────────────────────────────
# EXECUTION_MODE: mock | paper | canary | live.
#   mock   — synthetic venue (default, offline).
#   paper  — PaperVenue against real prices, simulated fills. No real orders.
#   canary — splits each parent across paper + real. Requires LIVE_TRADING_ARMED.
#   live   — all real venue. Requires LIVE_TRADING_ARMED=true AND MOCK_TRADING_ENABLED=false.
# CANARY_PAPER_PCT: percent of each parent sent to the paper leg under canary. 0..100.
# RECONCILIATION_INTERVAL_MS: how often the cron sweeps internal vs venue book.
# LIVE_TRADING_ARMED: engineering arm switch for real-money modes. Set true only
#   after real venue credentials are wired and a testnet round-trip has passed.
EXECUTION_MODE=mock
CANARY_PAPER_PCT=100
RECONCILIATION_INTERVAL_MS=60000
LIVE_TRADING_ARMED=false

# ── Telemetry / observability (P1) ──────────────────────────────────────────
# A config-gated swap seam (off by default ⇒ no-op, zero behaviour change). On ⇒
# Prometheus metrics at GET /metrics + GET /health[/ready] (liveness/readiness).
# TELEMETRY_ENABLED: master switch. false ⇒ /metrics returns a "disabled" note.
# TELEMETRY_READY_TICK_MULTIPLIER: /health/ready fails if the running loop's last
#   tick is older than N×MM_POLL_INTERVAL_MS (a stuck loop).
# TELEMETRY_FEED_STALENESS_MS: /health/ready fails if every running book's newest
#   bar is older than this (a dead feed). Also the feed-staleness gauge reference.
TELEMETRY_ENABLED=false
TELEMETRY_READY_TICK_MULTIPLIER=5
TELEMETRY_FEED_STALENESS_MS=120000
